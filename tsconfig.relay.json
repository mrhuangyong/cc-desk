{
  // 中继服务独立编译配置（Docker 部署用）。
  // 把 relay/*.ts + 依赖的 src/shared/remote-protocol*.ts 编译为 ESM JS，
  // 输出到 dist/，供容器内 `node dist/relay/main.js` 独立运行（不依赖 electron）。
  // 与根 tsconfig.json（electron-vite 用）分离，避免互相干扰。
  // 用法：tsc -p tsconfig.relay.json
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    // "bundler" 取代已移除的 "Node"(=node10)：TS 5.5+ 删除了 node10 解析。
    // bundler 与 module:CommonJS 兼容，支持省略相对路径导入的扩展名（relay 现有风格），
    // 且输出 CommonJS（node dist/relay/main.js 直接运行）。
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": false,
    "types": ["node", "ws"]
  },
  "include": [
    "relay/**/*.ts",
    "src/shared/remote-protocol.ts",
    "src/shared/remote-protocol-types.ts"
  ]
}
