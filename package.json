{
  "name": "cc-desk",
  "version": "1.20.1",
  "description": "",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:win": "electron-vite build && electron-builder --win",
    "build:linux": "electron-vite build && electron-builder --linux",
    "relay:build": "tsc -p tsconfig.relay.json",
    "relay:dev": "RELAY_PORT=8787 RELAY_DATA_DIR=./relay/data-local RELAY_STATIC_DIR=./relay/public node dist/relay/main.js",
    "web:dev": "cd web && VITE_RELAY_URL='ws://localhost:8787' pnpm dev",
    "dev:remote": "npm run relay:build && (npm run relay:dev & npm run web:dev & npm run dev)",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:watch": "vitest",
    "postinstall": "node scripts/fix-pty-perm.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.31.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "node-pty"
    ],
    "supportedArchitectures": {
      "os": [
        "current"
      ],
      "cpu": [
        "x64",
        "arm64"
      ],
      "libc": [
        "glibc",
        "musl"
      ]
    },
    "patchedDependencies": {
      "@tiptap/suggestion@3.27.0": "patches/@tiptap+suggestion.patch"
    }
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.178",
    "@monaco-editor/react": "^4.7.0",
    "@tiptap/core": "^3.27.0",
    "@tiptap/extension-placeholder": "^3.27.0",
    "@tiptap/pm": "^3.27.0",
    "@tiptap/react": "^3.27.0",
    "@tiptap/starter-kit": "^3.27.0",
    "@tiptap/suggestion": "^3.27.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.9",
    "ignore": "^7.0.5",
    "katex": "^0.17.0",
    "lucide-react": "^1.18.0",
    "mermaid": "^11.15.0",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.1.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shell-env": "^4.0.3",
    "shiki": "^4.2.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.3",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "build": {
    "appId": "com.cc-desk.app",
    "productName": "cc-desk",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "build/icons/**/*"
    ],
    "asarUnpack": [
      "node_modules/.pnpm/@anthropic-ai+claude-agent-sdk-*/node_modules/@anthropic-ai/claude-agent-sdk-*/claude*",
      "node_modules/@anthropic-ai/claude-agent-sdk-*/claude*"
    ],
    "mac": {
      "icon": "build/icons/icon.icns",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "icon": "build/icons/icon.png",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "build/icons/icon.png",
      "maintainer": "mrhuangyong <mrhuangyong@live.cn>",
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "mrhuangyong",
        "repo": "cc-desk"
      }
    ]
  },
  "optionalDependencies": {
    "@anthropic-ai/claude-agent-sdk-darwin-arm64": "0.3.178",
    "@anthropic-ai/claude-agent-sdk-darwin-x64": "0.3.178",
    "@anthropic-ai/claude-agent-sdk-linux-arm64": "0.3.178",
    "@anthropic-ai/claude-agent-sdk-linux-arm64-musl": "0.3.178",
    "@anthropic-ai/claude-agent-sdk-linux-x64": "0.3.178",
    "@anthropic-ai/claude-agent-sdk-linux-x64-musl": "0.3.178",
    "@anthropic-ai/claude-agent-sdk-win32-arm64": "0.3.178",
    "@anthropic-ai/claude-agent-sdk-win32-x64": "0.3.178"
  }
}
